configuration {
  modes: "window,drun,run,ssh";
  show-icons: true;
  terminal: "ghostty +new-terminal";
  display-drun: "Applications:";
  display-window: "Windows:";
  drun-display-format: "{name}";
  font: "Inter 12";
  timeout {
      action: "kb-cancel";
      delay:  0;
  }
  filebrowser {
      directories-first: true;
      sorting-method:    "name";
  }
}

@theme "./theme.rasi"
